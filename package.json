{
  "name": "xd-photovault",
  "private": true,
  "version": "2.2.1",
  "description": "小呆相册 - 照片管理与去重应用",
  "main": "dist-electron/main.js",
  "author": "小呆相册",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:zip": "npm run build && electron-builder --win zip",
    "dist:portable": "npm run build && electron-builder --win portable",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "test": "node scripts/pretest.mjs && vitest run && node scripts/posttest.mjs",
    "test:watch": "node scripts/pretest.mjs && vitest",
    "test:ui": "node scripts/pretest.mjs && vitest --ui",
    "verify": "npm run check && npm test",
    "verify:portable": "npm run verify && npm run dist:portable",
    "electron": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "download:ai-model": "node scripts/download-ai-model.mjs"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@huggingface/tokenizers": "^0.1.3",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.4",
    "exifr": "^7.1.3",
    "exiftool-vendored": "^36.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "hash-wasm": "^4.12.0",
    "i18next": "^26.3.6",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.511.0",
    "onnxruntime-node": "^1.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.9",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.3.0",
    "react-virtuoso": "^4.18.7",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.0.2",
    "uuid": "^10.0.0",
    "zustand": "^5.0.3"
  },
  "overrides": {
    "@xenova/transformers": {
      "sharp": "$sharp"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.25.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^8.2.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.xiaodai.album",
    "productName": "xd-PhotoVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sharp",
        "to": "node_modules/sharp"
      },
      {
        "from": "resources/ai-models",
        "to": "ai-models"
      }
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
